# --- Server ---
PORT=3000
NODE_ENV=production

# --- Meta WhatsApp Cloud API ---
# Choose any secret string; you'll paste the same one into Meta's webhook config.
META_VERIFY_TOKEN=change-me-to-a-long-random-string

# From Meta Business Suite > WhatsApp > API Setup > "Phone number ID"
META_PHONE_NUMBER_ID=

# From Meta Business Suite > WhatsApp > API Setup > "Access Token"
# Use a permanent System User token for production, not the temporary one.
META_WHATSAPP_ACCESS_TOKEN=

# --- Gemini (primary) ---
# From https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- OpenRouter (automatic fallback) ---
# When the direct Gemini call fails (billing block, auth, quota, 5xx, etc.)
# the bot transparently retries via OpenRouter, which routes to the same
# model family. Get a key + credits at https://openrouter.ai/keys
# Leave empty to disable the fallback (errors will propagate as before).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
# Optional attribution — shows up on OpenRouter's usage dashboard.
OPENROUTER_APP_NAME=Botifys Lead Desk
OPENROUTER_APP_URL=https://whatsapp.botifys.com

# --- SQLite ---
# Path is relative to the working directory. In Docker, mount a volume here.
DB_PATH=./data/leads.db

# --- Dashboard (Phase 2) ---
# Shared password your team will use to log into the lead dashboard.
DASHBOARD_PASSWORD=change-me-to-a-strong-password

# Used to sign session cookies. Must be at least 32 characters.
# Generate via: openssl rand -hex 32 (or any 32+ char random string)
SESSION_SECRET=change-me-to-a-random-32-plus-character-string

# --- Audio (Phase 3) ---
# Where uploaded call recordings live. In Docker, put on the same volume
# as the SQLite DB so files persist across redeploys.
AUDIO_DIR=./data/audio

# Per-upload ceiling. Default 100 MB covers a 50-min MP3 at 256 kbps.
MAX_AUDIO_BYTES=104857600

# --- Auto-upload (Phase 3.5) ---
# Shared bearer token for the salesperson's Android automation app
# (Automate / MacroDroid / Tasker) to POST call recordings automatically.
# Must be at least 24 characters. Rotate to revoke all devices at once.
# Generate via: openssl rand -hex 16  (or any random 24+ char string)
AUTO_UPLOAD_TOKEN=change-me-to-a-long-random-token

# --- Salesperson notifications (Phase 4) ---
# Comma-separated WhatsApp numbers (country code + number, no +) that
# should receive a notification when a new lead qualifies. E.g.:
# SALESPERSON_PHONES=919876543210,919876543211
# Leave empty to disable. NOTE: Meta requires those numbers to have
# messaged the bot in the last 24 hours, otherwise the notification will
# be rejected (we log a warning and continue).
SALESPERSON_PHONES=

# Public URL the salesperson notification links to (the dashboard origin).
DASHBOARD_PUBLIC_URL=https://whatsapp.botifys.com

# --- Error alerts (Phase 4) ---
# Sign up free at https://resend.com (3,000 emails/month free tier),
# generate an API key, paste here. Leave empty to disable email alerts.
RESEND_API_KEY=

# Where to send the alerts (your email).
ALERT_EMAIL=jitguard76@gmail

# Sender address. Default works out-of-the-box but Resend will only
# deliver to the email associated with your Resend account. For
# production, verify your domain in Resend and use alerts@yourdomain.com.
ALERT_FROM_EMAIL=onboarding@resend.dev

# --- Testing: force-treat Indian numbers as international (Phase 8) ---
# Comma-separated list of phone numbers (with 91 prefix, no +) that
# should go through the international Google Meet booking flow even
# though they're Indian. Use this to dry-run the international flow
# with your own +91 test number before pointing real overseas ads.
# Leave empty in production.
# Example: TEST_INTERNATIONAL_PHONES=919876543210,919812345678
TEST_INTERNATIONAL_PHONES=
