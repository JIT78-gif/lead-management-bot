# --- Server ---
PORT=3000
NODE_ENV=production

# --- Meta WhatsApp Cloud API ---
# Choose any secret string; you'll paste the same one into Meta's webhook config.
META_VERIFY_TOKEN=change-me-to-a-long-random-string

# From Meta Business Suite > WhatsApp > API Setup > "Phone number ID"
META_PHONE_NUMBER_ID=

# From Meta Business Suite > WhatsApp > API Setup > "Access Token"
# Use a permanent System User token for production, not the temporary one.
META_WHATSAPP_ACCESS_TOKEN=

# --- Gemini ---
# From https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- SQLite ---
# Path is relative to the working directory. In Docker, mount a volume here.
DB_PATH=./data/leads.db

# --- Dashboard (Phase 2) ---
# Shared password your team will use to log into the lead dashboard.
DASHBOARD_PASSWORD=change-me-to-a-strong-password

# Used to sign session cookies. Must be at least 32 characters.
# Generate via: openssl rand -hex 32 (or any 32+ char random string)
SESSION_SECRET=change-me-to-a-random-32-plus-character-string
